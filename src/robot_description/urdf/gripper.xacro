<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== MATERIALS ==================== -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>

  <!-- ==================== BASE / PALM ==================== -->
  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.05"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
    </collision>
  </link>

  <!-- ==================== FINGER 1 (front) ==================== -->
  <link name="finger_1_proximal">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.016 0.012 0.05"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.016 0.012 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="finger_1_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child  link="finger_1_proximal"/>
    <!-- Placed at the front of the palm -->
    <origin xyz="0.035 0.0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="2.0"/>
  </joint>

  <!-- ==================== FINGER 2 (rear-left) ==================== -->
  <link name="finger_2_proximal">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.016 0.012 0.05"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.016 0.012 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="finger_2_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child  link="finger_2_proximal"/>
    <!-- 120 deg offset around Z from finger 1 -->
    <origin xyz="-0.0175 0.0303 0.04" rpy="0 0 2.094"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="2.0"/>
    <mimic joint="finger_1_joint" multiplier="1.0" offset="0.0"/>
  </joint>

  <!-- ==================== FINGER 3 (rear-right) ==================== -->
  <link name="finger_3_proximal">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.016 0.012 0.05"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.016 0.012 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="finger_3_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child  link="finger_3_proximal"/>
    <!-- 240 deg offset around Z from finger 1 -->
    <origin xyz="-0.0175 -0.0303 0.04" rpy="0 0 4.189"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="10" velocity="2.0"/>
    <mimic joint="finger_1_joint" multiplier="1.0" offset="0.0"/>
  </joint>

</robot>
